export SEAWEED_HOST0=testbench
export SEAWEED_VOLUME_SIZE_MB=3 #1000

export AWS_ACCESS_KEY_ID=whatever
export AWS_SECRET_ACCESS_KEY=whatever

export REDIS_MAX_MEMORY=512mb

export WG_S3_IP=unset # Besure to specify this when using self-hosted S3 endpoints
export WG_DB_IP=unset # Besure to specify this when using self-hosted DB endpoints
export JFS_S3_ENDPOINT=wireguard_server:8333
#export JFS_S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
export JFS_S3_BUCKET_AND_KEY=test_bucket/test_key
export JFS_NAME=jfs
export JFS_CAPACITY_GB=100
export JFS_CACHE_SIZE_MB=10240
export JFS_BUFFER_SIZE_MB=300

export WG_CLIENT_IP=10.8.0.1
export WG_SERVER_ID=99

export DB_USER=app_admin

export GATEWAY_DEFAULT_REQ_RATE=256
export GATEWAY_DEFAULT_BURST=128
export GATEWAY_DEFAULT_CONN_MAX=32

export GATEWAY_CF_PROTECT=false

source secrets/config.env

export EMAIL_DOMAIN=$GATEWAY_DOMAIN
export ACME_EMAIL=acme@$EMAIL_DOMAIN
